ENVIRONMENT=development
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite (development)
DATABASE_URL=sqlite:///./tgs_dev.db

# PostgreSQL (production) — uncomment and set for prod
# DATABASE_URL=postgresql://user:password@localhost:5432/tgs_prod

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
